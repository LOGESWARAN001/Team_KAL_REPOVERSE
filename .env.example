# Optional — raises GitHub API rate limit from 60 to 5000 requests/hour.
# For Fire Building CI detection, enable the "actions:read" scope (classic token)
# or Actions read permission (fine-grained token).
# Create a token at https://github.com/settings/tokens (classic, public_repo + actions:read).
# Restart the dev server after saving this file.
VITE_GITHUB_TOKEN=

# Optional — for OAuth device flow (future). Token auth via landing page or modal works today.
# VITE_GITHUB_CLIENT_ID=
